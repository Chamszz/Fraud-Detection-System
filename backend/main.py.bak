from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
import pickle
import os
import sys
import uuid
sys.path.insert(0, os.path.dirname(os.path.dirname(__file__)))
from utils.features import extract_features, get_user_baseline
from backend.feedback import init_feedback_db, log_feedback
from backend.retrain import retrain_model

app = FastAPI()

# Initialize feedback database
init_feedback_db()

# Load model
model_path = os.path.join(os.path.dirname(os.path.dirname(__file__)), 'models', 'model.pkl')
with open(model_path, 'rb') as f:
    model = pickle.load(f)

# In-memory storage for pending transactions
pending_transactions = {}

class Transaction(BaseModel):
    cc_num: str
    amt: float
    hour: int
    minute: int = 0
    second: int = 0

class ResolveAction(BaseModel):
    action: str  # "approve" or "reject"

def format_12h(hour: int, minute: int = 0, second: int = 0) -> str:
    period = "AM" if hour < 12 else "PM"
    display_hour = hour % 12
    if display_hour == 0:
        display_hour = 12
    return f"{display_hour}:{minute:02d}:{second:02d} {period}"

@app.post("/transaction")
async def process_transaction(transaction: Transaction):
    trans_dict = transaction.dict()
    features = extract_features(trans_dict)

    # Predict risk
    score = model.decision_function([features])[0]
    base_risk = max(0, min(100, -score * 200))

    baseline = get_user_baseline(transaction.cc_num)
    risk = base_risk
    reason = "Suspicious transaction detected."

    if baseline:
        amount_ratio = transaction.amt / baseline['avg_amount'] if baseline['avg_amount'] > 0 else 1.0
        transaction_time = transaction.hour + transaction.minute / 60.0 + transaction.second / 3600.0
        raw_diff = abs(transaction_time - baseline['frequent_time'])
        time_diff = min(raw_diff, 24 - raw_diff)

        if amount_ratio >= 3:
            risk = max(risk, 95)
        elif amount_ratio >= 2:
            risk = max(risk, 90)
        elif amount_ratio > 1:
            risk = min(100, risk + int((amount_ratio - 1.0) * 25))

        risk = min(100, risk + int(time_diff * 2))

        if amount_ratio > 1.0:
            reason += f" Amount is {amount_ratio:.1f}x above the user's average."
        if time_diff > 1.0:
            reason += f" Time {format_12h(transaction.hour, transaction.minute, transaction.second)} is unusual (normal around {format_12h(int(baseline['frequent_time']), int((baseline['frequent_time'] % 1) * 60))})."

    if risk < 80:
        return {
            "status": "APPROVED",
            "risk_score": int(risk)
        }

    trans_id = str(uuid.uuid4())
    pending_transactions[trans_id] = {
        'transaction': trans_dict,
        'status': 'PENDING_USER_APPROVAL',
        'reason': reason,
        'risk_score': int(risk)
    }

    return {
        "status": "PENDING_USER_APPROVAL",
        "transaction_id": trans_id,
        "reason": reason,
        "risk_score": int(risk)
    }

@app.post("/transaction/{trans_id}/resolve")
async def resolve_transaction(trans_id: str, action: ResolveAction):
    if trans_id not in pending_transactions:
        raise HTTPException(status_code=404, detail="Transaction not found")

    if action.action == "approve":
        pending_transactions[trans_id]['status'] = "APPROVED"
    elif action.action == "reject":
        pending_transactions[trans_id]['status'] = "REJECTED"
    else:
        raise HTTPException(status_code=400, detail="Invalid action")

    return {
        "transaction_id": trans_id,
        "status": pending_transactions[trans_id]['status']
    }